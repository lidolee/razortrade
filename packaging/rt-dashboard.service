[Unit]
Description=razortrade dashboard (read-only portfolio view)
Documentation=file:/usr/share/doc/razortrade/README.md
After=network.target rt-daemon.service
# Dashboard is useful only if the daemon has written at least once;
# Wants (not Requires) so we still come up if the daemon is down.
Wants=rt-daemon.service

# Dashboard ist harmlos (read-only mode=ro gegen die SQLite) — wenn
# es crasht, restartet systemd einfach.
StartLimitBurst=5
StartLimitIntervalSec=60

[Service]
Type=exec
User=razortrade
Group=razortrade
# Dashboard needs to run `journalctl` as a subprocess for the live-log
# streaming endpoint. systemd-journal group grants read access to the
# system journal without needing root. Without this, journalctl returns
# only the user's own logs (empty for the razortrade service user).
SupplementaryGroups=systemd-journal

ExecStart=/usr/bin/rt-dashboard
Environment=RUST_LOG=info
Environment=DATABASE_URL=sqlite:///var/lib/razortrade/razortrade.sqlite?mode=ro
Environment=RT_DASHBOARD_BIND=127.0.0.1:8080

Restart=on-failure
RestartSec=5s

# Hardening. Dashboard does ONLY read queries plus local HTTP and
# the journalctl subprocess for live-log streaming — anything more
# paranoid than this would break one of those.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
PrivateDevices=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
RestrictNamespaces=true
LockPersonality=true
# NB: MemoryDenyWriteExecute removed in Drop 16 because some Go
# runtime paths inside journalctl's JSON output handling use JIT-ish
# memory patterns that were triggering SIGSYS under strict MDWX.
# The SystemCallArchitectures lockdown below still keeps the attack
# surface small; losing MDWX is an acceptable trade for the live-log
# feature.
SystemCallArchitectures=native
CapabilityBoundingSet=
ReadOnlyPaths=/var/lib/razortrade

TimeoutStopSec=15s

[Install]
WantedBy=multi-user.target
