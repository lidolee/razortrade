# Example daemon configuration.
# Install to /etc/razortrade/daemon.toml and adjust.

database_path = "/var/lib/razortrade/razortrade.sqlite"
signal_poll_interval_ms = 1000
kill_switch_check_interval_secs = 60

# ============================================================================
# Execution mode: the single most important safety switch in the system.
# ============================================================================
#
# "dry_run" — approved signals are LOGGED to the dry_run_orders table only.
#             No broker contact. This is the default and the expected mode
#             during bring-up and validation.
#
# "paper"   — orders are submitted to the broker's paper/demo/sandbox API.
#             Requires demo credentials. Broker submission is not wired yet;
#             approved signals in this mode are currently rejected with a
#             clear reason so they are never silently dropped.
#
# "live"    — orders go to the broker's PRODUCTION API. REAL MONEY AT RISK.
#             Requires production credentials AND a deliberate configuration
#             override. Not yet wired.
#
# Any value other than one of these three is rejected at config load time.
[execution]
mode = "dry_run"

[kraken]
products = ["PI_XBTUSD"]
demo = true

[risk]
# Check 1: staleness
# Swing-trading cadence: 4h Donchian decisions do not need sub-second
# freshness. 10s is tight enough to catch real feed outages and loose
# enough to survive brief low-volume hours.
max_tick_age_ms = 10000

# Check 2: spread & liquidity
max_spread_bps = "20"
min_book_depth_multiple = "3"
book_depth_levels = 5

# Check 3: volatility
max_atr_pct_for_leverage = "6"
max_atr_pct_absolute = "15"

# Check 4: hard limits
leverage_kill_switch_budget_chf = "-1000"
max_portfolio_drawdown = "0.20"
adverse_move_for_worst_case = "0.10"
max_leverage = "2"

# Check 5: funding rate
max_funding_rate_per_8h = "0.0002"

# Check 6: notional cap
# Per-order notional ceiling in CHF. Defensive cap against signal-generator
# bugs. Default 1000 — override if you run larger sleeves.
max_notional_chf_per_order = "1000"

# FX fallback used by the equity snapshot writer (Drop 12).
# USD per CHF. Default 1.10.
usd_per_chf_fallback = "1.10"
